---
import "../styles/global.css";
import Header from "../components/Header.astro";
import SobreNosotros from "../components/SobreNosotros.astro";
import Galeria from "../components/Galeria.astro";
import Contacto from "../components/Contacto.astro";

const pageTitle = "Finca Esmeralda";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />

    <section id="inicio" class="hero">
      <div class="hero-content">
        <h1>Bienvenido a Finca Esmeralda</h1>
        <p>
          Un lugar especial donde la tradición y la naturaleza se encuentran
        </p>
      </div>
    </section>

    <SobreNosotros />
    <Galeria />
    <Contacto />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 2rem;
    padding-top: 80px;
    position: relative;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    color: #000000;
  }

  .hero h1 {
    font-size: 4rem;
    font-weight: 800;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(255, 255, 255, 0.8);
    letter-spacing: -0.02em;
  }

  .hero p {
    font-size: 1.5rem;
    font-weight: 400;
    text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }
    .hero p {
      font-size: 1.2rem;
    }
  }
</style>
