---

<section id="contacto" class="contacto">
  <div class="container">
    <h2>Contacto</h2>
    <div class="content">
      <div class="info">
        <div class="info-item">
          <h3>📍 Dirección</h3>
          <p>Tu dirección aquí</p>
        </div>
        <div class="info-item">
          <h3>📞 Teléfono</h3>
          <p>+54 XXX XXX XXXX</p>
        </div>
        <div class="info-item">
          <h3>✉️ Email</h3>
          <p>contacto@fincaesmeralda.com</p>
        </div>
      </div>

      <form class="contact-form">
        <div class="form-group">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" name="nombre" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-group">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
        </div>
        <button type="submit" class="btn-submit">Enviar Mensaje</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contacto {
    min-height: 100vh;
    padding: 5rem 2rem;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(245, 245, 245, 0.98) 100%
    );
    display: flex;
    align-items: center;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  h2 {
    font-size: 3.5rem;
    margin-bottom: 4rem;
    color: #1a1a1a;
    text-align: center;
    font-weight: 800;
    position: relative;
    padding-bottom: 1rem;
  }

  h2::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .content {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: start;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    height: fit-content;
  }

  .info-item {
    padding: 1.5rem;
    border-left: 4px solid var(--color-primary);
    background: rgba(0, 0, 0, 0.03);
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .info-item:hover {
    transform: translateX(8px);
    background: rgba(0, 0, 0, 0.08);
  }

  .info-item h3 {
    font-size: 1.4rem;
    margin-bottom: 0.8rem;
    color: var(--color-primary);
    font-weight: 700;
  }

  .info-item p {
    font-size: 1.15rem;
    color: #555;
    line-height: 1.6;
  }

  .contact-form {
    background: white;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .form-group label {
    font-weight: 600;
    color: #2c3e50;
    font-size: 1rem;
  }

  .form-group input,
  .form-group textarea {
    padding: 1rem 1.2rem;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-family: var(--font-family);
    font-size: 1rem;
    transition: all 0.3s ease;
    background: #fafafa;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: white;
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .btn-submit {
    padding: 1.2rem 2.5rem;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 8px;
    font-family: var(--font-family);
    font-size: 1.15rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 0.5rem;
  }

  .btn-submit:hover {
    background: #333333;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  @media (max-width: 968px) {
    .content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .contacto {
      padding: 4rem 1.5rem;
    }

    h2 {
      font-size: 2.5rem;
      margin-bottom: 3rem;
    }

    .info {
      padding: 2rem;
    }

    .contact-form {
      padding: 2rem;
    }

    .info-item {
      padding: 1.2rem;
    }
  }
</style>
