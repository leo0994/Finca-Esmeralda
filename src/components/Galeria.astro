<section id="galeria" class="galeria">
  <div class="container">
    <h2>Galería</h2>
    <div class="grid">
      <div class="gallery-item">
        <img src="/placeholder1.jpg" alt="Imagen 1" />
      </div>
      <div class="gallery-item">
        <img src="/placeholder2.jpg" alt="Imagen 2" />
      </div>
      <div class="gallery-item">
        <img src="/placeholder3.jpg" alt="Imagen 3" />
      </div>
      <div class="gallery-item">
        <img src="/placeholder4.jpg" alt="Imagen 4" />
      </div>
      <div class="gallery-item">
        <img src="/placeholder5.jpg" alt="Imagen 5" />
      </div>
      <div class="gallery-item">
        <img src="/placeholder6.jpg" alt="Imagen 6" />
      </div>
    </div>
  </div>
</section>

<style>
  .galeria {
    min-height: 100vh;
    padding: 5rem 2rem;
    background: linear-gradient(
      135deg,
      rgba(26, 26, 26, 0.95) 0%,
      rgba(0, 0, 0, 0.9) 100%
    );
    display: flex;
    align-items: center;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  h2 {
    font-size: 3.5rem;
    margin-bottom: 3rem;
    color: var(--color-text-light);
    text-align: center;
    font-weight: 800;
    position: relative;
    padding-bottom: 1rem;
  }

  h2::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 4px;
    background: var(--color-primary);
    border-radius: 2px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 12px;
    cursor: pointer;
    transition: transform 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 8px 30px rgba(5, 150, 105, 0.4);
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.1);
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .galeria {
      padding: 4rem 1.5rem;
    }

    h2 {
      font-size: 2.5rem;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
